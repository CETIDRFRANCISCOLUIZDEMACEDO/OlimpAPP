import { Request, Response } from 'express'
import bcrypt from 'bcryptjs'
import jwt from 'jsonwebtoken'
import pool from '../config/database'

export async function register(req: Request, res: Response): Promise<void> {
  const { email, password, name, school, city, state, grade, olimpiadas } = req.body as {
    email?: string
    password?: string
    name?: string
    school?: string
    city?: string
    state?: string
    grade?: string
    olimpiadas?: string[]
  }

  if (!email || !password || !name) {
    res.status(400).json({ error: 'email, password e name são obrigatórios' })
    return
  }

  const client = await pool.connect()
  try {
    await client.query('BEGIN')

    const exists = await client.query('SELECT id FROM users WHERE email = $1', [email])
    if (exists.rows.length > 0) {
      await client.query('ROLLBACK')
      res.status(409).json({ error: 'E-mail já cadastrado' })
      return
    }

    const hash = await bcrypt.hash(password, 10)
    const userResult = await client.query<{ id: string }>(
      'INSERT INTO users (email, password) VALUES ($1, $2) RETURNING id',
      [email, hash]
    )
    const userId = userResult.rows[0]?.id

    await client.query(
      `INSERT INTO profiles (user_id, name, school, city, state, grade)
       VALUES ($1, $2, $3, $4, $5, $6)`,
      [userId, name, school ?? null, city ?? null, state ?? null, grade ?? null]
    )

    if (Array.isArray(olimpiadas) && olimpiadas.length > 0) {
      for (const olimpiada of olimpiadas) {
        await client.query(
          'INSERT INTO olimpiadas_interesse (user_id, olimpiada) VALUES ($1, $2)',
          [userId, olimpiada]
        )
      }
    }

    await client.query('COMMIT')

    const token = jwt.sign({ userId }, process.env['JWT_SECRET'] ?? '', { expiresIn: '7d' })
    res.status(201).json({ token })
  } catch (err) {
    await client.query('ROLLBACK')
    console.error(err)
    res.status(500).json({ error: 'Erro interno' })
  } finally {
    client.release()
  }
}

export async function login(req: Request, res: Response): Promise<void> {
  const { email, password } = req.body as { email?: string; password?: string }

  if (!email || !password) {
    res.status(400).json({ error: 'email e password são obrigatórios' })
    return
  }

  try {
    const result = await pool.query<{ id: string; password: string }>(
      'SELECT id, password FROM users WHERE email = $1',
      [email]
    )

    if (result.rows.length === 0) {
      res.status(401).json({ error: 'Credenciais inválidas' })
      return
    }

    const user = result.rows[0]!
    const valid = await bcrypt.compare(password, user.password)
    if (!valid) {
      res.status(401).json({ error: 'Credenciais inválidas' })
      return
    }

    const token = jwt.sign({ userId: user.id }, process.env['JWT_SECRET'] ?? '', { expiresIn: '7d' })
    res.json({ token })
  } catch (err) {
    console.error(err)
    res.status(500).json({ error: 'Erro interno' })
  }
}
